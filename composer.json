{
    "name": "pro/cloud-migration-monitor",
    "type": "project",
    "description": "Real-time dashboard tracking VM migration status.",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^10.0",
        "aws/aws-sdk-php": "^3.283",
        "guzzlehttp/guzzle": "^7.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
